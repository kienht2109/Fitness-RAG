# Application
APP_NAME=AI Workout Coach
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_JUDGE_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chroma
# CHROMA_HOST and CHROMA_PORT are set to the internal service address by Compose.
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_SSL=false
CHROMA_EXPOSED_PORT=8001
CHROMA_IMAGE=chromadb/chroma:1.5.9
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
CHROMA_COLLECTION=fitness_knowledge

# Retrieval and agent behavior
RAG_TOP_K=5
RAG_CHUNK_MIN_TOKENS=120
RAG_CHUNK_TARGET_TOKENS=300
RAG_CHUNK_MAX_TOKENS=450
RAG_CHUNK_OVERLAP_TOKENS=40
RAG_EMBEDDING_BATCH_SIZE=64
AGENT_MAX_ITERATIONS=5

# Local data paths (Compose replaces these with /app/data paths).
KNOWLEDGE_BASE_DIR=data/knowledge_base
WORKOUT_HISTORY_PATH=data/workout-history.json
